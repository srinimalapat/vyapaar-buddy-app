            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"itemName\": \"Toor Dal 1kg\",\n  \"category\": \"Pulses\",\n  \"quantityAvailable\": 8,\n  \"lowStockThreshold\": 15,\n  \"unitPrice\": 120.00\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/inventory", "host": ["{{baseUrl}}"], "path": ["api","v1","inventory"] }
          }

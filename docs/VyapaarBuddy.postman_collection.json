            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/credits/pending-customers", "host": ["{{baseUrl}}"], "path": ["api","v1","credits","pending-customers"] }
          }
        },
        {
          "name": "Total Outstanding Credit",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/credits/total-outstanding", "host": ["{{baseUrl}}"], "path": ["api","v1","credits","total-outstanding"] }
          }

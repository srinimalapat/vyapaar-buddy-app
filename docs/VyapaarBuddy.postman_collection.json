            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": {{customerId}},\n  \"transactionType\": \"PAYMENT_RECEIVED\",\n  \"amount\": 150.00,\n  \"description\": \"Cash payment received\",\n  \"transactionDate\": \"2026-05-20\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/credits/payments", "host": ["{{baseUrl}}"], "path": ["api","v1","credits","payments"] }

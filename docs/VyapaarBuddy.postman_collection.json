{
  "info": {
    "name": "Vyapaar Buddy API",
    "_postman_id": "vyapaar-buddy-v1",
    "description": "Full API collection for Vyapaar Buddy. Flow: Register → Create Business → Add Customers → Sales / Credits / Inventory / Reminders.\n\nThe {{token}} variable is auto-set after Register or Login.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080", "type": "string" },
    { "key": "token",   "value": "",                      "type": "string" },
    { "key": "customerId", "value": "",                   "type": "string" },
    { "key": "saleId",     "value": "",                   "type": "string" },
    { "key": "inventoryId","value": "",                   "type": "string" },
    { "key": "reminderId", "value": "",                   "type": "string" }
  ],
  "item": [
    {
      "name": "1 · Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if (res.data && res.data.token) {",
                  "  pm.collectionVariables.set('token', res.data.token);",
                  "  console.log('Token saved:', res.data.token.substring(0,30)+'...');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Ramesh Sharma\",\n  \"email\": \"ramesh@testshop.com\",\n  \"password\": \"password123\",\n  \"phone\": \"9876543210\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api","auth","register"] }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if (res.data && res.data.token) {",
                  "  pm.collectionVariables.set('token', res.data.token);",
                  "  console.log('Token saved');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"ramesh@testshop.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api","auth","login"] }
          }
        }
      ]
    },
    {
      "name": "2 · Business Profile",
      "item": [
        {
          "name": "Create Business Profile",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ownerName\": \"Ramesh Sharma\",\n  \"mobileNumber\": \"9876543210\",\n  \"businessName\": \"Ramesh Kirana Store\",\n  \"businessType\": \"GROCERY\",\n  \"city\": \"Pune\",\n  \"state\": \"Maharashtra\",\n  \"preferredLanguage\": \"HINDI\",\n  \"address\": \"123 MG Road, Pune\",\n  \"pinCode\": \"411001\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/business", "host": ["{{baseUrl}}"], "path": ["api","v1","business"] }
          }
        },
        {
          "name": "Get My Business",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/business/me", "host": ["{{baseUrl}}"], "path": ["api","v1","business","me"] }
          }
        },
        {
          "name": "Update Business Profile",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ownerName\": \"Ramesh Sharma\",\n  \"mobileNumber\": \"9876543210\",\n  \"businessName\": \"Ramesh Kirana & General Store\",\n  \"businessType\": \"GROCERY\",\n  \"city\": \"Pune\",\n  \"state\": \"Maharashtra\",\n  \"preferredLanguage\": \"HINDI\",\n  \"address\": \"123 MG Road, Pune\",\n  \"pinCode\": \"411001\",\n  \"gstNumber\": \"27AAAAA0000A1Z5\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/business/me", "host": ["{{baseUrl}}"], "path": ["api","v1","business","me"] }
          }
        }
      ]
    },
    {
      "name": "3 · Customers",
      "item": [
        {
          "name": "Add Customer (Suresh)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if (res.data && res.data.id) {",
                  "  pm.collectionVariables.set('customerId', res.data.id);",
                  "  console.log('Customer ID saved:', res.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerName\": \"Suresh Patil\",\n  \"mobileNumber\": \"9823456789\",\n  \"address\": \"45 Laxmi Nagar, Pune\",\n  \"notes\": \"Regular customer\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/customers", "host": ["{{baseUrl}}"], "path": ["api","v1","customers"] }
          }
        },
        {
          "name": "Add Customer (Priya)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerName\": \"Priya Desai\",\n  \"mobileNumber\": \"9712345678\",\n  \"address\": \"12 Shivaji Nagar, Pune\",\n  \"notes\": \"Wholesale buyer\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/customers", "host": ["{{baseUrl}}"], "path": ["api","v1","customers"] }
          }
        },
        {
          "name": "List All Customers",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/customers", "host": ["{{baseUrl}}"], "path": ["api","v1","customers"] }
          }
        },
        {
          "name": "Get Customer by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/customers/{{customerId}}", "host": ["{{baseUrl}}"], "path": ["api","v1","customers","{{customerId}}"] }
          }
        },
        {
          "name": "Search Customers",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/customers/search?query=suresh",
              "host": ["{{baseUrl}}"], "path": ["api","v1","customers","search"],
              "query": [{ "key": "query", "value": "suresh" }]
            }
          }
        },
        {
          "name": "Update Customer",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerName\": \"Suresh Patil\",\n  \"mobileNumber\": \"9823456789\",\n  \"address\": \"45 Laxmi Nagar, Pune - Updated\",\n  \"notes\": \"Regular customer - VIP\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/customers/{{customerId}}", "host": ["{{baseUrl}}"], "path": ["api","v1","customers","{{customerId}}"] }
          }
        },
        {
          "name": "Deactivate Customer",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/customers/{{customerId}}", "host": ["{{baseUrl}}"], "path": ["api","v1","customers","{{customerId}}"] }
          }
        }
      ]
    },
    {

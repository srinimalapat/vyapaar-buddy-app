              "query": [{ "key": "date", "value": "2026-05-20" }]
            }
          }
        },
        {
          "name": "Monthly Sales Summary",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/sales/summary/monthly?year=2026&month=5",
              "host": ["{{baseUrl}}"], "path": ["api","v1","sales","summary","monthly"],
              "query": [
                { "key": "year",  "value": "2026" },
                { "key": "month", "value": "5" }
              ]
            }
          }
        }
      ]
    },
    {

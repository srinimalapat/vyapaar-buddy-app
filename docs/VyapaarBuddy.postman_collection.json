    {
      "name": "5 · Sales",
      "item": [
        {
          "name": "Create Cash Sale (auto-reduces inventory)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if (res.data && res.data.id) {",
                  "  pm.collectionVariables.set('saleId', res.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"saleType\": \"CASH\",\n  \"totalAmount\": 900.00,\n  \"paidAmount\": 900.00,\n  \"items\": [\n    {\n      \"itemName\": \"Basmati Rice 5kg\",\n      \"quantity\": 2,\n      \"unitPrice\": 450.00\n    }\n  ]\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/sales", "host": ["{{baseUrl}}"], "path": ["api","v1","sales"] }
          }
        },
        {
          "name": "Create Credit Sale (udhaar — customer required)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"saleType\": \"CREDIT\",\n  \"customerId\": {{customerId}},\n  \"totalAmount\": 560.00,\n  \"paidAmount\": 200.00,\n  \"items\": [\n    {\n      \"itemName\": \"Toor Dal 1kg\",\n      \"quantity\": 2,\n      \"unitPrice\": 120.00\n    },\n    {\n      \"itemName\": \"Sugar 1kg\",\n      \"quantity\": 1,\n      \"unitPrice\": 50.00\n    }\n  ]\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/sales", "host": ["{{baseUrl}}"], "path": ["api","v1","sales"] }
          }
        },
        {
          "name": "Get Sale by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/sales/{{saleId}}", "host": ["{{baseUrl}}"], "path": ["api","v1","sales","{{saleId}}"] }
          }
        },
        {
          "name": "List All Sales",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/sales", "host": ["{{baseUrl}}"], "path": ["api","v1","sales"] }
          }
        },
        {
          "name": "List Sales (date range)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/sales?fromDate=2026-05-01&toDate=2026-05-31",
              "host": ["{{baseUrl}}"], "path": ["api","v1","sales"],
              "query": [
                { "key": "fromDate", "value": "2026-05-01" },
                { "key": "toDate",   "value": "2026-05-31" }
              ]
            }
          }
        },
        {
          "name": "Daily Sales Summary",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/sales/summary/daily?date=2026-05-20",

              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"itemName\": \"Basmati Rice 5kg\",\n  \"category\": \"Grains\",\n  \"quantityAvailable\": 100,\n  \"lowStockThreshold\": 20,\n  \"unitPrice\": 450.00\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/inventory", "host": ["{{baseUrl}}"], "path": ["api","v1","inventory"] }
          }
        },
        {
          "name": "Add Inventory Item (Toor Dal)",

    {
      "name": "7 · Reminders",
      "item": [
        {
          "name": "Generate Reminder for Customer (auto Hindi message)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if (res.data && res.data.id) {",
                  "  pm.collectionVariables.set('reminderId', res.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": { "mode": "raw", "raw": "" },
            "url": { "raw": "{{baseUrl}}/api/v1/reminders/customer/{{customerId}}", "host": ["{{baseUrl}}"], "path": ["api","v1","reminders","customer","{{customerId}}"] }
          }
        },
        {
          "name": "Generate Reminder (custom amount + message)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amountDue\": 500.00,\n  \"reminderDate\": \"2026-05-25\",\n  \"channel\": \"WHATSAPP_MANUAL\",\n  \"message\": \"Dear Suresh ji, please pay Rs 500 at your earliest. Thank you!\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/reminders/customer/{{customerId}}", "host": ["{{baseUrl}}"], "path": ["api","v1","reminders","customer","{{customerId}}"] }
          }
        },
        {
          "name": "Bulk Generate Reminders (all debtors)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/reminders/bulk", "host": ["{{baseUrl}}"], "path": ["api","v1","reminders","bulk"] }
          }
        },
        {
          "name": "List All Reminders",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/reminders", "host": ["{{baseUrl}}"], "path": ["api","v1","reminders"] }
          }
        },
        {
          "name": "List Reminders for Customer",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/reminders?customerId={{customerId}}",
              "host": ["{{baseUrl}}"], "path": ["api","v1","reminders"],
              "query": [{ "key": "customerId", "value": "{{customerId}}" }]
            }
          }
        },
        {
          "name": "Get Reminder by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/reminders/{{reminderId}}", "host": ["{{baseUrl}}"], "path": ["api","v1","reminders","{{reminderId}}"] }
          }
        },
        {
          "name": "Mark Reminder as Sent",
          "request": {
